---
import AppLayout from "@/layouts/AppLayout.astro";
import { ProjectDetailPage } from "@/components/proyectos/ProjectDetailPage";

const { id } = Astro.params;
const tab = Astro.url.searchParams.get("tab") || undefined;
---

<AppLayout title="Detalle de Proyecto" currentPath="/proyectos">
  <ProjectDetailPage projectId={id} initialTab={tab} client:load />
</AppLayout>
